# ============================================================
# DriveWise environment configuration
# Copy to .env and adjust. Every value here has a safe default
# in app/config/settings.py, but be explicit in real deployments.
# ============================================================

APP_NAME=DriveWise
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Database ---
DATABASE_URL=postgresql+asyncpg://drivewise:drivewise@localhost:5432/drivewise

# --- Storage ---
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=storage/uploads
MAX_UPLOAD_SIZE_MB=25

# --- PDF Parser: pymupdf | pdfplumber ---
PDF_PARSER=pymupdf

# --- Chunking ---
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP_TOKENS=60

# --- Embeddings: sentence_transformers | openai ---
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# --- Vector store: faiss | chroma ---
VECTOR_DB=faiss
FAISS_INDEX_PATH=storage/vectors/faiss_index
CHROMA_PERSIST_DIR=storage/vectors/chroma

# --- Reranker: bge | none ---
RERANKER=bge
RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_TOP_K=5
RETRIEVAL_TOP_K=20

# --- LLM provider: ollama | openai | gemini | groq ---
# Development (recommended): fully local, free, no rate limits.
LLM_PROVIDER=ollama

# Production example (uncomment/edit when deploying):
#   LLM_PROVIDER=groq
#   LLM_FALLBACK_PROVIDERS=["gemini"]
# If Groq's free tier gets rate-limited, DriveWise automatically retries
# with Gemini before giving up. Leave as [] to disable fallback (default).
LLM_FALLBACK_PROVIDERS=[]

OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
